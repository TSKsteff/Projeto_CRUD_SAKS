<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20"
      alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="br.saks.register_services.views.adm.AdmEditView"
      prefWidth="800"
      prefHeight="600">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="titleLabel"
               text="Edit User"
               style="-fx-font-size: 22; -fx-font-weight: bold;"/>
    </HBox>

    <GridPane hgap="30" vgap="15" style="-fx-padding: 20;">

        <Label text="Name" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Email" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Phone" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="CPF" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="cpfField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Role" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="roleCombo"
                  prefWidth="200"
                  GridPane.rowIndex="4"
                  GridPane.columnIndex="1"/>

    </GridPane>

    <Label fx:id="errorLabel"
           style="-fx-text-fill: red; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="Cancel" onAction="#handleCancel"/>
        <Button text="Save" onAction="#handleSave"/>

    </HBox>

</VBox>